{
  "name": "react-editor",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n \"SERVER,CLIENT\" -c \"green.bold,blue.bold\" \"npm run server\" \"npm run client\"",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "lodash.debounce": "^4.0.8"
  },
  "devDependencies": {
    "@types/lodash.debounce": "^4.0.9"
  }
}
